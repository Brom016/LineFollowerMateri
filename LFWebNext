#define STBY  18
#define BIN1  19
#define BIN2  21
#define PWMB  22

// ─────────────────────────────────────────────
//  PIN SENSOR  (semua ADC1 → aman saat WiFi ON)
// ─────────────────────────────────────────────
#define S1  36   // ADC1_CH0
#define S2  39   // ADC1_CH3
#define S3  34   // ADC1_CH6
#define S4  35   // ADC1_CH7
#define S5  32   // ADC1_CH4
#define S6  33   // ADC1_CH5

const int SENSOR_PINS[6] = {S1, S2, S3, S4, S5, S6};

// Bobot posisi: S1(kiri jauh)=-5 … S6(kanan jauh)=+5
const float WEIGHT[6] = {-5.0f, -3.0f, -1.0f, 1.0f, 3.0f, 5.0f};

// ─────────────────────────────────────────────
//  PWM  (ESP32 Arduino Core v3.x)
// ─────────────────────────────────────────────
#define PWM_FREQ   10000   // 10 kHz
#define PWM_RES        8   // 8-bit → 0–255

// ─────────────────────────────────────────────
//  PARAMETER KECEPATAN (bisa diubah dari Web UI)
// ─────────────────────────────────────────────
int baseNormal  = 90;   // PWM saat lurus
int baseSharp   = 70;   // PWM saat tikungan tajam
int maxSpeed    = 120;  // batas atas output PID
int searchSpeed = 75;   // PWM saat cari garis (spin)

// ─────────────────────────────────────────────
//  KALIBRASI SENSOR
// ─────────────────────────────────────────────
#define ADC_MAX        4095
#define CALIB_TIME_MS  5000
#define SAMPLES           4
#define THRESH_FACTOR  0.55f

int sensorMin[6];
int sensorMax[6];
int sensorThreshold[6];
int sensorVal[6];
int rawVals[6];

// ─────────────────────────────────────────────
//  PID
// ─────────────────────────────────────────────
float pidInput = 0.0f, pidOutput = 0.0f, pidSetpoint = 0.0f;
float Kp = 22.0f, Ki = 0.05f, Kd = 20.0f;

QuickPID pid(
  &pidInput, &pidOutput, &pidSetpoint,
  Kp, Ki, Kd,
  QuickPID::pMode::pOnError,
  QuickPID::dMode::dOnMeas,
  QuickPID::iAwMode::iAwClamp,
  QuickPID::Action::direct
);

// ─────────────────────────────────────────────
//  STATE MESIN
