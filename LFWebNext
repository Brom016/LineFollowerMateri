float lastPos        = 0.0f;
bool  robotRunning   = false;
bool  isCalibrating  = false;
unsigned long calibStart = 0;
bool  priorityLeft   = true;

int    motorL_val    = 0;
int    motorR_val    = 0;
String robotStateStr = "IDLE";
String statusMessage = "";

