// ═══════════════════════════════════════════════════════════════
//  MOTOR FUNCTIONS
// ═══════════════════════════════════════════════════════════════
void initMotor() {
  ledcAttach(PWMA, PWM_FREQ, PWM_RES);
  ledcAttach(PWMB, PWM_FREQ, PWM_RES);

  pinMode(AIN1, OUTPUT); pinMode(AIN2, OUTPUT);
  pinMode(BIN1, OUTPUT); pinMode(BIN2, OUTPUT);
  pinMode(STBY, OUTPUT);
  digitalWrite(STBY, HIGH);
}

void driveMotorL(int sp) {
  sp = constrain(sp, -255, 255);
  if      (sp > 0) { digitalWrite(AIN1, HIGH); digitalWrite(AIN2, LOW); }
  else if (sp < 0) { digitalWrite(AIN1, LOW);  digitalWrite(AIN2, HIGH); sp = -sp; }
  else             { digitalWrite(AIN1, LOW);   digitalWrite(AIN2, LOW); }
  ledcWrite(PWMA, (uint32_t)sp);
  motorL_val = sp;
}

void driveMotorR(int sp) {
  sp = constrain(sp, -255, 255);
  if      (sp > 0) { digitalWrite(BIN1, HIGH); digitalWrite(BIN2, LOW); }
  else if (sp < 0) { digitalWrite(BIN1, LOW);  digitalWrite(BIN2, HIGH); sp = -sp; }
  else             { digitalWrite(BIN1, LOW);   digitalWrite(BIN2, LOW); }
  ledcWrite(PWMB, (uint32_t)sp);
  motorR_val = sp;
}

void stopMotor() {
  driveMotorL(0);
  driveMotorR(0);
}

// ═══════════════════════════════════════════════════════════════
//  SENSOR READING
// ═══════════════════════════════════════════════════════════════
void readSensor() {
  for (int i = 0; i < 6; i++) {
    long sum = 0;
    for (int s = 0; s < SAMPLES; s++) sum += analogRead(SENSOR_PINS[i]);
    rawVals[i]   = (int)(sum / SAMPLES);
    sensorVal[i] = (rawVals[i] < sensorThreshold[i]) ? 1 : 0;
  }
}

// ═══════════════════════════════════════════════════════════════
//  POSISI ANALOG BERBOBOT
// ═══════════════════════════════════════════════════════════════
float getPosition() {
  float wSum  = 0.0f;
  float total = 0.0f;

  for (int i = 0; i < 6; i++) {
    int range = sensorMax[i] - sensorMin[i];
    if (range < 150) continue;

    float norm = (float)(sensorThreshold[i] - rawVals[i])
               / (float)(sensorThreshold[i] - sensorMin[i] + 1);
    norm = constrain(norm, 0.0f, 1.0f);

    if (norm > 0.15f) {
      wSum  += WEIGHT[i] * norm;
      total += norm;
    }
  }

  if (total < 0.15f) return lastPos;

  float pos = wSum / total;
  lastPos = pos;
  return pos;
}

// ═══════════════════════════════════════════════════════════════
//  KALIBRASI
// ═══════════════════════════════════════════════════════════════
void startCalibration() {
  for (int i = 0; i < 6; i++) {
    sensorMin[i] = ADC_MAX;
    sensorMax[i] = 0;
  }
  isCalibrating = true;
  calibStart    = millis();
  robotRunning  = false;
  stopMotor();
  robotStateStr = "CALIB";
  statusMessage = "📐 Kalibrasi berjalan... gerakkan robot!";
}

void saveCalibration() {
  prefs.begin("calib", false);
  for (int i = 0; i < 6; i++) {
    prefs.putInt(("mn" + String(i)).c_str(), sensorMin[i]);
    prefs.putInt(("mx" + String(i)).c_str(), sensorMax[i]);
    prefs.putInt(("th" + String(i)).c_str(), sensorThreshold[i]);
  }
  prefs.end();
}

void loadCalibration() {
  prefs.begin("calib", true);
  if (prefs.isKey("mn0")) {
    for (int i = 0; i < 6; i++) {
      sensorMin[i]       = prefs.getInt(("mn" + String(i)).c_str(), ADC_MAX);
      sensorMax[i]       = prefs.getInt(("mx" + String(i)).c_str(), 0);
      sensorThreshold[i] = prefs.getInt(("th" + String(i)).c_str(), ADC_MAX / 2);
    }
  }
  prefs.end();
}

void clearCalibration() {
  prefs.begin("calib", false);
  prefs.clear();
  prefs.end();
  for (int i = 0; i < 6; i++) {
    sensorMin[i] = ADC_MAX; sensorMax[i] = 0;
    sensorThreshold[i] = ADC_MAX / 2;
  }
}

// ═══════════════════════════════════════════════════════════════
//  SAVE / LOAD ALL SETTINGS
// ═══════════════════════════════════════════════════════════════
void saveAllSettings() {
  prefs.begin("cfg", false);
  prefs.putFloat("Kp", Kp);  prefs.putFloat("Ki", Ki);  prefs.putFloat("Kd", Kd);
  prefs.putInt("bN", baseNormal); prefs.putInt("bS", baseSharp);
  prefs.putInt("mS", maxSpeed);   prefs.putInt("sS", searchSpeed);
  prefs.putBool("pL", priorityLeft);
  prefs.end();
}

void loadAllSettings() {
  prefs.begin("cfg", true);
  if (prefs.isKey("Kp")) {
    Kp          = prefs.getFloat("Kp", 22.0f);
    Ki          = prefs.getFloat("Ki", 0.05f);
    Kd          = prefs.getFloat("Kd", 20.0f);
    baseNormal  = prefs.getInt("bN", 90);
    baseSharp   = prefs.getInt("bS", 70);
    maxSpeed    = prefs.getInt("mS", 120);
    searchSpeed = prefs.getInt("sS", 75);
    priorityLeft = prefs.getBool("pL", true);
    pid.SetTunings(Kp, Ki, Kd);
    pid.SetOutputLimits(-maxSpeed, maxSpeed);
  }
  prefs.end();
}

// ═══════════════════════════════════════════════════════════════
//  KONTROL PID
// ═══════════════════════════════════════════════════════════════
void pidControl() {
  float pos    = getPosition();
  pidInput     = pos;
  pidSetpoint  = 0.0f;
  pid.Compute();

  int L = baseNormal + (int)pidOutput;
  int R = baseNormal - (int)pidOutput;

  L = constrain(L, -maxSpeed, maxSpeed);
  R = constrain(R, -maxSpeed, maxSpeed);

  driveMotorL(L);
  driveMotorR(R);
  robotStateStr = "FOLLOW";
}

// ═══════════════════════════════════════════════════════════════
//  SEARCH LINE
// ═══════════════════════════════════════════════════════════════
void searchLine() {
  if (lastPos <= 0.0f) {
    driveMotorL(-searchSpeed);
    driveMotorR(searchSpeed);
    robotStateStr = "SEARCH_L";
  } else {
    driveMotorL(searchSpeed);
    driveMotorR(-searchSpeed);
    robotStateStr = "SEARCH_R";
  }
}

// ═══════════════════════════════════════════════════════════════
//  STATUS JSON
// ═══════════════════════════════════════════════════════════════
void handleStatus() {
  String j = "{";
  j += "\"kp\":"          + String(Kp, 2)          + ",";
  j += "\"ki\":"          + String(Ki, 3)          + ",";
  j += "\"kd\":"          + String(Kd, 2)          + ",";
  j += "\"state\":\""     + robotStateStr          + "\",";
  j += "\"error\":"       + String(pidInput, 2)    + ",";
  j += "\"motorL\":"      + String(motorL_val)     + ",";
  j += "\"motorR\":"      + String(motorR_val)     + ",";
  j += "\"baseNormal\":"  + String(baseNormal)     + ",";
  j += "\"baseSharp\":"   + String(baseSharp)      + ",";
  j += "\"maxSpeed\":"    + String(maxSpeed)       + ",";
  j += "\"searchSpeed\":" + String(searchSpeed)    + ",";
  j += "\"priorityLeft\":" + String(priorityLeft ? 1 : 0) + ",";
  j += "\"message\":\""   + statusMessage          + "\",";
  j += "\"sensors\":[";
  for (int i = 0; i < 6; i++) { j += String(rawVals[i]); if (i < 5) j += ","; }
  j += "],\"sensorActive\":[";
  for (int i = 0; i < 6; i++) { j += String(sensorVal[i]); if (i < 5) j += ","; }
  j += "]}";
  server.send(200, "application/json", j);
}

// ═══════════════════════════════════════════════════════════════
//  SETUP
// ═══════════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  Serial.println("\n=== Line Follower PID — ESP32 ===");

  for (int i = 0; i < 6; i++) {
    pinMode(SENSOR_PINS[i], INPUT);
    sensorMin[i] = ADC_MAX; sensorMax[i] = 0;
    sensorThreshold[i] = ADC_MAX / 2;
  }

  initMotor();
  stopMotor();

  loadCalibration();
  loadAllSettings();

  WiFi.mode(WIFI_AP);
  WiFi.softAP(AP_SSID, AP_PASS);
  Serial.println("WiFi AP: " + String(AP_SSID));
  Serial.println("Web UI : http://" + WiFi.softAPIP().toString());

  pid.SetOutputLimits(-maxSpeed, maxSpeed);
  pid.SetSampleTimeUs(5000);
  pid.SetMode(QuickPID::Control::automatic);

  server.on("/", HTTP_GET, []() {
    server.send_P(200, "text/html", INDEX_HTML);
  });

  server.on("/status", HTTP_GET, handleStatus);

  server.on("/set_pid", HTTP_POST, []() {
    if (server.hasArg("kp")) Kp = server.arg("kp").toFloat();
    if (server.hasArg("ki")) Ki = server.arg("ki").toFloat();
    if (server.hasArg("kd")) Kd = server.arg("kd").toFloat();
    pid.SetTunings(Kp, Ki, Kd);
    Serial.printf("PID updated → Kp=%.2f Ki=%.3f Kd=%.2f\n", Kp, Ki, Kd);
    server.send(200, "text/plain", "OK");
  });

  server.on("/set_speed", HTTP_POST, []() {
    if (server.hasArg("base_normal"))  baseNormal  = server.arg("base_normal").toInt();
    if (server.hasArg("base_sharp"))   baseSharp   = server.arg("base_sharp").toInt();
    if (server.hasArg("max_speed"))    maxSpeed    = server.arg("max_speed").toInt();
    if (server.hasArg("search_speed")) searchSpeed = server.arg("search_speed").toInt();
    if (server.hasArg("priority_left")) priorityLeft = (server.arg("priority_left") == "1");
    pid.SetOutputLimits(-maxSpeed, maxSpeed);
    Serial.printf("Speed updated → N=%d S=%d Max=%d Srch=%d\n",
                  baseNormal, baseSharp, maxSpeed, searchSpeed);
    server.send(200, "text/plain", "OK");
  });

  server.on("/start", HTTP_POST, []() {
    robotRunning  = true;
    robotStateStr = "FOLLOW";
    statusMessage = "▶ Robot berjalan";
    Serial.println("Robot STARTED");
    server.send(200, "text/plain", "OK");
  });

  server.on("/stop", HTTP_POST, []() {
    robotRunning  = false;
    stopMotor();
    robotStateStr = "IDLE";
    statusMessage = "■ Robot dihentikan";
    Serial.println("Robot STOPPED");
    server.send(200, "text/plain", "OK");
  });

  server.on("/calibrate", HTTP_POST, []() {
    startCalibration();
    server.send(200, "text/plain", "OK");
  });

  server.on("/save_calib", HTTP_POST, []() {
    saveCalibration();
    statusMessage = "💾 Kalibrasi disimpan ke Flash";
    server.send(200, "text/plain", "OK");
  });

  server.on("/load_calib", HTTP_POST, []() {
    loadCalibration();
    statusMessage = "📤 Kalibrasi dimuat dari Flash";
    server.send(200, "text/plain", "OK");
  });

  server.on("/clear_calib", HTTP_POST, []() {
    clearCalibration();
    statusMessage = "🗑 Data kalibrasi dihapus";
    server.send(200, "text/plain", "OK");
  });

  server.on("/save_settings", HTTP_POST, []() {
    saveAllSettings();
    statusMessage = "💾 Semua setting disimpan";
    server.send(200, "text/plain", "OK");
  });

  server.on("/load_settings", HTTP_POST, []() {
    loadAllSettings();
    statusMessage = "📤 Setting dimuat";
    server.send(200, "text/plain", "OK");
  });

  server.begin();
  Serial.println("HTTP server ready.");
  Serial.println("=================================");
}

// ═══════════════════════════════════════════════════════════════
//  LOOP UTAMA
// ═══════════════════════════════════════════════════════════════
void loop() {
  server.handleClient();
  readSensor();

  if (isCalibrating) {
    unsigned long elapsed = millis() - calibStart;
    if (elapsed < CALIB_TIME_MS) {
      for (int i = 0; i < 6; i++) {
        if (rawVals[i] < sensorMin[i]) sensorMin[i] = rawVals[i];
        if (rawVals[i] > sensorMax[i]) sensorMax[i] = rawVals[i];
      }
    } else {
      for (int i = 0; i < 6; i++) {
        int range = sensorMax[i] - sensorMin[i];
        sensorThreshold[i] = (range < 150)
          ? ADC_MAX / 2
          : sensorMin[i] + (int)(range * THRESH_FACTOR);
      }
      isCalibrating = false;
      robotStateStr = "IDLE";
      statusMessage = "✅ Kalibrasi selesai! Tekan SIMPAN KALIBRASI.";
      Serial.println("Calibration done:");
      for (int i = 0; i < 6; i++) {
        Serial.printf("  S%d → min=%d max=%d th=%d\n",
          i+1, sensorMin[i], sensorMax[i], sensorThreshold[i]);
      }
    }
  }

  else if (robotRunning) {
    int activeCount = 0;
    for (int i = 0; i < 6; i++) if (sensorVal[i]) activeCount++;

    if (activeCount >= 1) {
      pidControl();
    } else {
      searchLine();
    }
  }

  else {
    stopMotor();
    robotStateStr = "IDLE";
  }

  delay(3);
}
